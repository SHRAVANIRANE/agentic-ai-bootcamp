APP_NAME=Inventory Demand Forecasting Agent
DEBUG=false

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
LLM_TEMPERATURE=0.1

# Forecasting
FORECAST_HORIZON_DAYS=30
SAFETY_STOCK_MULTIPLIER=1.5
LEAD_TIME_DAYS=7

# Cache
FORECAST_CACHE_TTL=3600

# Redis
REDIS_URL=redis://localhost:6379
